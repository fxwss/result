{
  "$schema": "https://biomejs.dev/schemas/2.4.10/schema.json",
  "files": {
    "includes": ["src/**"]
  },
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100,
    "lineEnding": "lf"
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "single",
      "trailingCommas": "all",
      "semicolons": "asNeeded",
      "arrowParentheses": "always",
      "bracketSpacing": true,
      "bracketSameLine": false,
      "quoteProperties": "asNeeded",
      "attributePosition": "auto"
    }
  },
  "linter": {
    "enabled": true,
    "rules": {
      "a11y": "error",
      "complexity": "error",
      "correctness": "error",
      "performance": "error",
      "security": "error",
      "style": {
        "useExportsLast": "off"
      },
      "suspicious": "error",
      "nursery": {
        "noConditionalExpect": "error",
        "noContinue": "error",
        "noDeprecatedMediaType": "error",
        "noDivRegex": "error",
        "noDuplicatedSpreadProps": "error",
        "noEqualsToNull": "error",
        "noExcessiveClassesPerFile": "error",
        "noExcessiveLinesPerFile": "error",
        "noFloatingPromises": "error",
        "noForIn": "error",
        "noImpliedEval": "error",
        "noIncrementDecrement": "error",
        "noLeakedRender": "error",
        "noMisusedPromises": "error",
        "noMultiAssign": "error",
        "noMultiStr": "error",
        "noNestedPromises": "error",
        "noParametersOnlyUsedInRecursion": "error",
        "noProto": "error",
        "noRedundantDefaultExport": "error",
        "noReturnAssign": "error",
        "noShadow": "error",
        "noTernary": "off",
        "noTopLevelLiterals": "error",
        "noUnsafePlusOperands": "error",
        "noUselessReturn": "error",
        "noAmbiguousAnchorText": "error",
        "noEmptyObjectKeys": "error",
        "useArraySome": "error",
        "useArraySortCompare": "error",
        "useAwaitThenable": "error",
        "useConsistentEnumValueType": "error",
        "useConsistentMethodSignatures": "error",
        "useDestructuring": "error",
        "useErrorCause": "error",
        "useExhaustiveSwitchCases": "error",
        "useExpect": "error",
        "useExplicitType": "error",
        "useFind": "error",
        "useGlobalThis": "error",
        "useNamedCaptureGroup": "error",
        "useNullishCoalescing": "error",
        "useSpread": "error",
        "useUnicodeRegex": "error",
        "noUnnecessaryConditions": "error",
        "noDuplicateSelectors": "error",
        "noDuplicateEnumValues": "error"
      }
    }
  },
  "assist": {
    "enabled": true,
    "actions": {
      "source": {
        "organizeImports": "on"
      }
    }
  },
  "overrides": [
    {
      "includes": ["**/*.test.ts"],
      "linter": {
        "rules": {
          "style": {
            "noMagicNumbers": "off",
            "useNamingConvention": "off"
          },
          "complexity": {
            "noExcessiveLinesPerFunction": "off"
          },
          "nursery": {
            "noConditionalExpect": "off",
            "noExcessiveLinesPerFile": "off",
            "noExcessiveClassesPerFile": "off",
            "useExplicitType": "off",
            "noTopLevelLiterals": "off"
          }
        }
      }
    },
    {
      "includes": ["**/index.ts"],
      "linter": {
        "rules": {
          "performance": {
            "noBarrelFile": "off"
          }
        }
      }
    },
    {
      "includes": ["**/errors.ts"],
      "linter": {
        "rules": {
          "security": {
            "noSecrets": "off"
          },
          "nursery": {
            "noExcessiveClassesPerFile": "off"
          }
        }
      }
    }
  ]
}
